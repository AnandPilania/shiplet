# Shiplet — Express Docker Example
APP_PORT=3000
NODE_ENV=development
TZ=UTC

# PostgreSQL
POSTGRES_USER=shiplet
POSTGRES_PASSWORD=secret
POSTGRES_DB=app
POSTGRES_PORT=5432
DATABASE_URL=postgresql://shiplet:secret@postgres:5432/app

# Redis
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# Mailpit
SMTP_HOST=mailpit
SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Adminer
ADMINER_PORT=8080
